---
import BaseLayout from '../layouts/BaseLayout.astro';

// NOTE: the live "A Chef" section shows 4 specific process frames (grill, patty,
// box, ordering). Those exact frames aren't available yet — using stand-ins for now.
const grid = [
  { src: '/images/frame-61.jpg', alt: 'RoboBurger featured on Shark Tank' },
  { src: '/images/mask-group.png', alt: 'RoboBurger machine' },
  { src: '/images/feature-woman.png', alt: 'RoboBurger machine in a food court' },
  { src: '/images/newport.png', alt: 'Customer with a fresh RoboBurger' },
];

const certs = [
  { src: '/images/image-4.png', alt: 'ETL certified' },
  { src: '/images/cert-copyright.png', alt: 'Copyright' },
  { src: '/images/image-1.png', alt: 'Patented' },
  { src: '/images/cert-2.png', alt: 'CE marked' },
  { src: '/images/image-5.png', alt: 'NSF certified' },
];

const features = [
  {
    title: '24/7 Hot Food, No Staff Needed',
    text: "RoboBurger operates reliably around the clock, solving labor shortages in locations where kitchens can't go.",
    img: '/images/feature-woman.png',
    imgAlt: 'RoboBurger machine, as seen on Shark Tank',
  },
  {
    title: 'Low-Cost, High Return Model',
    text: 'Own multiple units for less than one restaurant; scalable, profitable, and ideal for modern food entrepreneurs.',
    img: '/images/newport.png',
    imgAlt: 'RoboBurger installed at a venue',
  },
  {
    title: 'Compact & Kitchen Free',
    text: 'Only 10 sq. ft., no kitchen buildout or grease trap, just plug in and serve real burgers anywhere.',
    img: '/images/machine.png',
    imgAlt: 'Compact RoboBurger machine',
  },
];

const locations = [
  { label: 'Malls', icon: 'mall' },
  { label: 'Airports', icon: 'airport-1' },
  { label: 'Universities', icon: 'school' },
  { label: 'Office Buildings', icon: 'office-building' },
  { label: 'Hospitals', icon: 'hospital' },
  { label: 'Hotels', icon: 'travel' },
  { label: 'Tourist Sites', icon: 'travel' },
  { label: 'Stadiums', icon: 'stadium' },
  { label: 'Cinemas', icon: 'cinema-screen' },
  { label: 'Amusement Parks', icon: 'amusement-park' },
  { label: 'Train Stations', icon: 'train' },
  { label: 'Gas Stations', icon: 'gas-station' },
  { label: 'Gyms', icon: 'gym' },
  { label: 'Convenience Stores', icon: 'convenience-store' },
  { label: 'Event Venues', icon: 'red-carpet' },
  { label: 'Industrial Zones', icon: 'industrial-zone' },
];

const stats = [
  { label: 'Limited Launch', value: 'Only 200 machines available' },
  { label: 'Secure Yours Today', value: 'Pay just $5,000 upfront' },
  { label: 'Special Pre-Order Price', value: '$27,500' },
];

const testimonials = [
  { quote: 'This burger is really good!', name: 'Lori Greiner', role: 'Shark Tank', img: '/images/image-7.png' },
  { quote: 'This is a big idea!', name: 'Michael Rubin', role: 'Shark Tank', img: '/images/image-6.png' },
];
---
<BaseLayout
  title="RoboBurger"
  description="RoboBurger is the world's first fully autonomous burger machine — grilling and serving fresh, hot burgers on demand, with no staff, kitchen, or ventilation."
>
  <!-- HERO -->
  <section class="hero">
    <img class="curve curve-left" src="/images/vector-6.png" alt="" aria-hidden="true" />
    <img class="curve curve-right" src="/images/vector-6.png" alt="" aria-hidden="true" />
    <div class="container hero-inner">
      <div class="hero-copy">
        <h1>The World's First Burger Chef In a Vending Format</h1>
        <p>
          RoboBurger™ is the first and only fully autonomous burger machine that grills and serves
          fresh, hot burgers on demand. Compact, self cleaning, and certified for food and electrical
          safety, it operates without staff, kitchen, or ventilation. Backed by multiple patents and
          global interest from leading food, retail, and tech companies.
        </p>
        <a href="/contact-us/" class="btn btn-primary">Contact us</a>
      </div>
      <div class="hero-media">
        <img src="/images/mask-group.png" alt="RoboBurger autonomous burger machine" width="520" height="640" />
      </div>
    </div>
  </section>

  <!-- A CHEF. A KITCHEN. A BUSINESS. IN A BOX -->
  <section class="chef">
    <div class="container chef-inner">
      <h2>A Chef. A Kitchen. A Business. In a Box</h2>
      <div class="chef-grid">
        {grid.map((g) => <div class="chef-cell"><img src={g.src} alt={g.alt} loading="lazy" /></div>)}
      </div>
    </div>
  </section>

  <!-- CERTIFICATIONS -->
  <section class="certs">
    <div class="container">
      <ul class="cert-row">
        {certs.map((c) => <li><img src={c.src} alt={c.alt} loading="lazy" /></li>)}
      </ul>
    </div>
  </section>

  <!-- KEY FEATURES -->
  <section class="section features">
    <div class="container">
      <h2 class="section-title">RoboBurger: The Game Changing Burger Robot</h2>
      <p class="section-lead">Scalable, flexible, and built for the future of food.</p>
      <div class="feature-grid">
        {features.map((f) => (
          <article class="feature-card">
            <p class="feature-text"><strong>{f.title}</strong> {f.text}</p>
            <div class="feature-img"><img src={f.img} alt={f.imgAlt} loading="lazy" /></div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- VALUE PROPOSITION + LOCATIONS -->
  <section class="section value">
    <div class="container">
      <h2 class="section-title">Innovation, Revenue, and Real Value</h2>
      <p class="section-lead">
        Bring innovation and revenue to your location, or launch a new business with a single machine.
        RoboBurger delivers hot, fresh grilled burgers from a fully automated robot, creating a
        futuristic food experience that attracts attention, delights customers, and generates consistent
        income. With low startup costs, no staff, and easy setup, it's the smartest way to grow your
        business or start one that people can't ignore.
      </p>
      <ul class="locations">
        {locations.map((loc) => (
          <li>
            <span class="loc-icon"><img src={`/images/loc/${loc.icon}.png`} alt="" aria-hidden="true" loading="lazy" /></span>
            <span class="loc-label">{loc.label}</span>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- PRE-ORDER GEN 3 -->
  <section class="section preorder">
    <div class="container preorder-inner">
      <div class="preorder-media">
        <img src="/images/product-web.webp" alt="RoboBurger Gen 3" width="480" height="480" />
      </div>
      <div class="preorder-copy">
        <h2>Pre Order RoboBurger Gen 3</h2>
        <p>
          Gen 3 is finally here faster, smaller, higher capacity, more menu options, and upgraded
          quality. This is the first RoboBurger designed for mass production and global expansion.
        </p>
        <div class="preorder-cta">
          <a href="/contact-us/" class="btn btn-primary">Contact Us To Reserve</a>
          <a href="/contact-us/" class="btn btn-outline btn-outline-light">Contact Us</a>
        </div>
        <p class="preorder-note">* Only 128 out of 200 are still available for pre-order.</p>
        <ul class="stats">
          {stats.map((s) => (
            <li><span class="stat-label">{s.label}</span><span class="stat-value">{s.value}</span></li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <!-- TESTIMONIALS -->
  <section class="section testimonials">
    <div class="container">
      <div class="testimonial-grid">
        {testimonials.map((t) => (
          <figure class="testimonial">
            <img class="tst-photo" src={t.img} alt={t.name} loading="lazy" />
            <blockquote>“{t.quote}”</blockquote>
            <figcaption><strong>{t.name}</strong><span>{t.role}</span></figcaption>
          </figure>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .section { padding: 4.5rem 0; }
  .section-title {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: clamp(1.9rem, 4vw, 2.8rem);
    text-align: center;
    line-height: 1.1;
  }
  .section-lead {
    max-width: 860px; margin: 0 auto 2.5rem; text-align: center;
    color: var(--color-text); font-size: 1.1rem;
  }

  /* HERO */
  .hero { position: relative; background: #fadbdc; overflow: hidden; }
  .hero-inner {
    position: relative; z-index: 2;
    display: grid; grid-template-columns: 1.05fr 0.95fr;
    align-items: center; gap: 2rem; padding-block: 3.5rem;
  }
  .curve { position: absolute; z-index: 1; height: 115%; width: auto; top: -5%; opacity: 1; pointer-events: none; }
  .curve-left { left: -2%; transform: scaleX(-1); }
  .curve-right { right: -2%; }
  .hero-copy h1 {
    font-family: var(--font-display); font-weight: 800;
    font-size: clamp(2.1rem, 5.2vw, 3.6rem); line-height: 1.05; margin-bottom: 1.25rem;
  }
  .hero-copy p { font-size: 1.1rem; color: #2b2b2b; margin-bottom: 1.75rem; max-width: 34rem; }
  .hero-media img { margin-inline: auto; max-height: 640px; width: auto; object-fit: contain; }

  /* A CHEF */
  .chef {
    background-image: url('/images/frame-125.png');
    background-size: cover; background-position: center;
    color: var(--color-white); padding: 4.5rem 0;
  }
  .chef-inner { display: grid; grid-template-columns: 1fr 1fr; gap: 2.5rem; align-items: center; }
  .chef h2 {
    color: var(--color-white); font-family: var(--font-display); font-weight: 800;
    font-size: clamp(1.9rem, 4.5vw, 3.1rem); line-height: 1.1;
  }
  .chef-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
  .chef-cell { border-radius: 10px; overflow: hidden; aspect-ratio: 4 / 3; background: rgba(255,255,255,0.06); }
  .chef-cell img { width: 100%; height: 100%; object-fit: cover; }

  /* CERTIFICATIONS */
  .certs { background: var(--color-white); padding: 2.5rem 0; border-bottom: 1px solid #f0f0f0; }
  .cert-row { list-style: none; margin: 0; padding: 0; display: flex; flex-wrap: wrap; justify-content: space-around; align-items: center; gap: 2rem; }
  .cert-row img { height: 56px; width: auto; object-fit: contain; }

  /* FEATURES */
  .features { background: var(--color-white); }
  .feature-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 2rem; }
  .feature-card { text-align: center; }
  .feature-text { color: var(--color-text); font-size: 1.05rem; margin-bottom: 1.25rem; }
  .feature-text strong { color: var(--color-heading); }
  .feature-img { border-radius: 12px; overflow: hidden; aspect-ratio: 4 / 3; background: var(--color-light); }
  .feature-img img { width: 100%; height: 100%; object-fit: cover; }

  /* VALUE + LOCATIONS */
  .value { background: var(--color-light); }
  .locations {
    list-style: none; padding: 0; margin: 0;
    display: grid; grid-template-columns: repeat(8, 1fr); gap: 1.25rem 0.75rem;
  }
  .locations li { display: flex; flex-direction: column; align-items: center; gap: 0.6rem; text-align: center; }
  .loc-icon {
    display: grid; place-items: center;
    width: 68px; height: 68px; border-radius: 50%;
    background: var(--color-red);
    box-shadow: 0 6px 16px rgba(226,0,12,0.25);
  }
  .loc-icon img { width: 36px; height: 36px; object-fit: contain; }
  .loc-label { font-size: 0.85rem; font-weight: 600; color: var(--color-heading); }

  /* PRE-ORDER */
  .preorder { background: var(--color-black); color: #e6e6e6; }
  .preorder-inner { display: grid; grid-template-columns: 0.9fr 1.1fr; gap: 2.5rem; align-items: center; }
  .preorder-media img { margin-inline: auto; border-radius: 12px; }
  .preorder-copy h2 { color: var(--color-white); font-family: var(--font-display); font-weight: 800; font-size: clamp(1.8rem, 4vw, 2.6rem); }
  .preorder-copy p { color: #cfcfcf; font-size: 1.08rem; }
  .preorder-cta { display: flex; flex-wrap: wrap; gap: 1rem; margin: 1.5rem 0; }
  .btn-outline-light { border-color: var(--color-white); color: var(--color-white); }
  .btn-outline-light:hover { background: var(--color-white); color: var(--color-black); }
  .preorder-note { font-size: 0.95rem; color: var(--color-yellow); }
  .stats { list-style: none; padding: 0; margin: 1.5rem 0 0; display: grid; gap: 1rem; }
  .stats li { display: flex; flex-direction: column; padding: 1rem 1.25rem; background: #141414; border-left: 4px solid var(--color-red); border-radius: 6px; }
  .stat-label { font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.04em; color: #9a9a9a; }
  .stat-value { font-size: 1.2rem; font-weight: 700; color: var(--color-white); }

  /* TESTIMONIALS */
  .testimonials { background: var(--color-light); }
  .testimonial-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.5rem; max-width: 900px; margin-inline: auto; }
  .testimonial { margin: 0; background: var(--color-white); border-radius: 14px; padding: 2rem; box-shadow: 0 6px 20px rgba(0,0,0,0.05); text-align: center; }
  .tst-photo { width: 84px; height: 84px; border-radius: 50%; object-fit: cover; margin: 0 auto 1rem; }
  .testimonial blockquote { margin: 0 0 1rem; font-family: var(--font-display); font-weight: 800; font-size: 1.4rem; color: var(--color-heading); }
  .testimonial figcaption { color: var(--color-muted); display: flex; flex-direction: column; }
  .testimonial figcaption strong { color: var(--color-red); }

  /* RESPONSIVE */
  @media (max-width: 900px) {
    .hero-inner, .chef-inner, .preorder-inner { grid-template-columns: 1fr; }
    .hero-media { order: -1; }
    .feature-grid { grid-template-columns: 1fr; max-width: 480px; margin-inline: auto; }
    .locations { grid-template-columns: repeat(4, 1fr); }
    .testimonial-grid { grid-template-columns: 1fr; }
    .curve { opacity: 0.5; }
  }
  @media (max-width: 520px) {
    .chef-grid { grid-template-columns: 1fr 1fr; }
    .locations { grid-template-columns: repeat(3, 1fr); }
  }
</style>
