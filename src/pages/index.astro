---
import BaseLayout from '../layouts/BaseLayout.astro';

// NOTE: some exact images still to be sourced (flagged): the "A Chef" 2x2 process
// frames (grill/patty/box), the promo video URL, and the "food empire" collage photos.
const gridVideos = [
  '/videos/Grill-30-noaudio.mp4',
  '/videos/clip-05-50-noaudio.mp4',
  '/videos/clip-01-100-noaudio.mp4',
  '/videos/clip-03-30-noaudio.mp4',
];

// Certification bar order matches the live site: NSF, ETL, ©, Patented, CE
const certs = [
  { src: '/images/image-5.png', alt: 'NSF certified' },
  { src: '/images/image-4.png', alt: 'ETL certified' },
  { src: '/images/cert-copyright.png', alt: 'Copyright' },
  { src: '/images/image-1.png', alt: 'Patented' },
  { src: '/images/cert-2.png', alt: 'CE marked' },
];

const features = [
  {
    title: '24/7 Hot Food, No Staff Needed',
    text: "RoboBurger operates reliably around the clock, solving labor shortages in locations where kitchens can't go.",
    img: '/images/feature-woman.png',
    imgAlt: 'RoboBurger machine, as seen on Shark Tank',
  },
  {
    title: 'Low-Cost, High Return Model',
    text: 'Own multiple units for less than one restaurant; scalable, profitable, and ideal for modern food entrepreneurs.',
    img: '/images/newport.png',
    imgAlt: 'Customer receiving a RoboBurger',
  },
  {
    title: 'Compact & Kitchen Free',
    text: 'Only 10 sq. ft., no kitchen buildout or grease trap, just plug in and serve real burgers anywhere.',
    img: '/images/machine.png',
    imgAlt: 'Customers using a compact RoboBurger machine',
  },
];

const stats = [
  { icon: 'rocket', text: 'Limited Launch: Only 200 machines available' },
  { icon: 'coins', text: 'Secure Yours Today: Pay just $5,000 upfront' },
  { icon: 'tag', text: 'Special Pre-Order Price: $27,500' },
];

const testimonials = [
  { quote: 'This burger is really good!', name: 'Lori Greiner', role: 'Shark Tank', img: '/images/image-7.png' },
  { quote: 'This is a big idea!', name: 'Michael Rubin', role: 'Shark Tank', img: '/images/image-6.png' },
];

const locations = [
  { label: 'Malls', icon: 'mall' },
  { label: 'Airports', icon: 'airport-1' },
  { label: 'Universities', icon: 'school' },
  { label: 'Office Buildings', icon: 'office-building' },
  { label: 'Hospitals', icon: 'hospital' },
  { label: 'Tourist Sites', icon: 'travel' },
  { label: 'Stadiums', icon: 'stadium' },
  { label: 'Cinemas', icon: 'cinema-screen' },
  { label: 'Amusement Parks', icon: 'amusement-park' },
  { label: 'Train Stations', icon: 'train' },
  { label: 'Gas Stations', icon: 'gas-station' },
  { label: 'Gyms', icon: 'gym' },
  { label: 'Convenience Stores', icon: 'convenience-store' },
  { label: 'Event Venues', icon: 'red-carpet' },
  { label: 'Industrial Zones', icon: 'industrial-zone' },
];
---
<BaseLayout
  title="RoboBurger"
  description="RoboBurger is the world's first fully autonomous burger machine — grilling and serving fresh, hot burgers on demand, with no staff, kitchen, or ventilation."
>
  <!-- 1. HERO -->
  <section class="hero">
    <img class="curve curve-left" src="/images/vector-6.png" alt="" aria-hidden="true" />
    <img class="curve curve-right" src="/images/vector-6-1.png" alt="" aria-hidden="true" />
    <div class="container hero-inner">
      <div class="hero-copy">
        <h1 class="zoom-in-fast">The World's First Burger Chef In a Vending Format</h1>
        <p>
          RoboBurger™ is the first and only fully autonomous burger machine that grills and serves
          fresh, hot burgers on demand. Compact, self cleaning, and certified for food and electrical
          safety, it operates without staff, kitchen, or ventilation. Backed by multiple patents and
          global interest from leading food, retail, and tech companies.
        </p>
        <a href="/contact-us/" class="btn btn-primary">Contact us</a>
      </div>
      <div class="hero-media">
        <img src="/images/mask-group.png" alt="RoboBurger autonomous burger machine" width="520" height="640" />
      </div>
    </div>
  </section>

  <!-- 2. A CHEF -->
  <section class="chef">
    <div class="container chef-inner">
      <h2>A Chef. A Kitchen. A Business. In a Box</h2>
      <div class="chef-grid">
        {gridVideos.map((src) => (
          <div class="chef-cell">
            <video src={src} autoplay loop muted playsinline preload="metadata"></video>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 3. CERTIFICATIONS (continuous auto-scrolling strip, matches the live site's carousel) -->
  <section class="certs">
    <div class="cert-marquee">
      <ul class="cert-track">
        {[...certs, ...certs, ...certs].map((c) => <li><img src={c.src} alt={c.alt} loading="lazy" /></li>)}
      </ul>
    </div>
  </section>

  <!-- 4. KEY FEATURES -->
  <section class="section features">
    <div class="container">
      <h2 class="section-title">RoboBurger: The Game Changing Burger Robot</h2>
      <p class="section-lead">Scalable, flexible, and built for the future of food.</p>
      <div class="feature-grid">
        {features.map((f) => (
          <article class="feature-card">
            <p class="feature-text"><strong>{f.title}</strong> {f.text}</p>
            <div class="feature-img"><img src={f.img} alt={f.imgAlt} loading="lazy" /></div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- 5. PRE-ORDER GEN 3 -->
  <section class="preorder">
    <div class="container preorder-inner">
      <div class="preorder-copy">
        <h2>Pre Order RoboBurger Gen 3</h2>
        <p>
          Gen 3 is finally here faster, smaller, higher capacity, more menu options, and upgraded
          quality. This is the first RoboBurger designed for mass production and global expansion.
        </p>
        <a href="/contact-us/" class="btn btn-primary preorder-cta">Contact Us To Reserve</a>
        <div class="preorder-count"><span class="big-num">128</span></div>
        <p class="preorder-note">Only 128 out of 200 are still available for pre order.</p>
      </div>
      <ul class="stat-cards">
        {stats.map((s) => (
          <li class="stat-card">
            <span class="stat-ic">
              <img src={`/images/icon-${s.icon}.png`} alt="" aria-hidden="true" />
            </span>
            <span class="stat-txt">{s.text}</span>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- 6. VIDEO -->
  <section class="video">
    <div class="container">
      <button
        type="button"
        class="video-card"
        data-yt="RNHAISIQpuU"
        aria-label="Play video: The Fully Automated Burger Kitchen"
      >
        <img src="/images/video-cover.png" alt="RoboBurger — The Fully Automated Burger Kitchen. Powered by Sweet Robo." loading="lazy" />
        <span class="play"><svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg></span>
      </button>
    </div>
  </section>

  <script>
    document.querySelectorAll('.video-card[data-yt]').forEach((card) => {
      card.addEventListener('click', () => {
        const id = card.getAttribute('data-yt');
        const iframe = document.createElement('iframe');
        iframe.src = `https://www.youtube-nocookie.com/embed/${id}?autoplay=1`;
        iframe.title = 'RoboBurger video';
        iframe.allow = 'accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture';
        iframe.allowFullscreen = true;
        iframe.style.cssText = 'position:absolute;inset:0;width:100%;height:100%;border:0;';
        card.replaceChildren(iframe);
      }, { once: true });
    });
  </script>

  <!-- 7. TESTIMONIALS (Shark Tank) -->
  <section class="testimonials" style={`background-image: linear-gradient(rgba(0,0,0,0.12), rgba(0,0,0,0.12)), url('/images/frame-61.jpg');`}>
    <img class="shark-logo" src="/images/shark-tank-logo.png" alt="As seen on Shark Tank" />
    <div class="container">
      <div class="testimonial-stack">
        {testimonials.map((t) => (
          <figure class="testimonial">
            <img class="tst-photo" src={t.img} alt={t.name} loading="lazy" />
            <blockquote>“{t.quote}”</blockquote>
            <figcaption>{t.name}, {t.role}</figcaption>
          </figure>
        ))}
      </div>
    </div>
  </section>

  <!-- 8. INNOVATION + LOCATIONS -->
  <section class="value">
    <div class="container">
      <h2 class="value-title">Innovation, Revenue, and Real Value</h2>
      <p class="value-lead">
        Bring innovation and revenue to your location, or launch a new business with a single machine.
        RoboBurger delivers hot, fresh grilled burgers from a fully automated robot, creating a
        futuristic food experience that attracts attention, delights customers, and generates consistent
        income. With low startup costs, no staff, and easy setup, it's the smartest way to grow your
        business or start one that people can't ignore.
      </p>
      <ul class="locations">
        {locations.map((loc) => (
          <li class="loc-card">
            <img class="loc-icon" src={`/images/loc/${loc.icon}.png`} alt="" aria-hidden="true" loading="lazy" />
            <span class="loc-label">{loc.label}</span>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- 9. FOOD EMPIRE (banner image from the live site) -->
  <section class="empire">
    <picture>
      <source media="(max-width: 700px)" srcset="/images/empire-mobile.jpg" />
      <img src="/images/empire-desktop.jpg" alt="RoboBurger is not just a machine. It's the next food empire!" loading="lazy" />
    </picture>
  </section>
</BaseLayout>

<style>
  .section { padding: 4.5rem 0; }
  .section-title { font-family: var(--font-display); font-weight: 800; font-size: clamp(1.9rem, 4vw, 2.8rem); text-align: center; line-height: 1.1; }
  .section-lead { max-width: 860px; margin: 0 auto 2.5rem; text-align: center; color: var(--color-text); font-size: 1.1rem; }

  /* 1. HERO */
  .hero { position: relative; background: #fadbdc; overflow: hidden; }
  .hero-inner { position: relative; z-index: 2; display: grid; grid-template-columns: 1.05fr 0.95fr; align-items: center; gap: 2rem; padding-block: 3.5rem; }
  .curve { position: absolute; z-index: 1; height: 100%; width: auto; bottom: 0; pointer-events: none; }
  .curve-left { left: 0; }
  .curve-right { right: 0; }
  .hero-copy h1 { font-family: var(--font-display); font-weight: 800; font-size: clamp(2.1rem, 5.2vw, 3.6rem); line-height: 1.05; margin-bottom: 1.25rem; }
  .hero-copy p { font-size: 1.1rem; color: #2b2b2b; margin-bottom: 1.75rem; max-width: 34rem; }
  .hero-media img { margin-inline: auto; max-height: 640px; width: auto; object-fit: contain; }

  /* Entrance animation on the hero heading, matching the live site's
     Elementor "_animation: zoomIn" (speed: fast = 0.75s), from animate.css */
  .zoom-in-fast { animation: zoomIn 0.75s; }
  @keyframes zoomIn {
    0%   { opacity: 0; transform: scale3d(0.3, 0.3, 0.3); }
    50%  { opacity: 1; }
    100% { transform: scale3d(1, 1, 1); }
  }
  @media (prefers-reduced-motion: reduce) {
    .zoom-in-fast { animation: none; }
  }

  /* 2. A CHEF */
  .chef { background-image: url('/images/frame-125.png'); background-size: cover; background-position: center; color: var(--color-white); padding: 4.5rem 0; }
  .chef-inner { display: grid; grid-template-columns: 1fr 1fr; gap: 2.5rem; align-items: center; }
  .chef h2 { color: var(--color-white); font-family: var(--font-display); font-weight: 800; font-size: clamp(1.9rem, 4.5vw, 3.1rem); line-height: 1.1; }
  .chef-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
  .chef-cell { overflow: hidden; aspect-ratio: 4 / 3; background: rgba(255,255,255,0.06); }
  .chef-cell img, .chef-cell video { width: 100%; height: 100%; object-fit: cover; display: block; }

  /* 3. CERTIFICATIONS — step carousel matching the live site's Swiper settings:
     slides_to_show:5, autoplay_speed:1000ms (hold), speed:500ms (transition), infinite loop, pause on hover. */
  .certs { background: var(--color-white); padding: 2.5rem 0; }
  .cert-marquee { overflow: hidden; width: 100%; }
  .cert-track {
    list-style: none; margin: 0; padding: 0;
    display: flex; width: 300%;
    animation: cert-scroll 7.5s ease infinite;
  }
  .cert-track li { flex: 0 0 calc(100% / 15); display: flex; justify-content: center; align-items: center; padding-inline: 1.5rem; }
  .cert-track img { height: 54px; width: auto; object-fit: contain; }
  .cert-marquee:hover .cert-track { animation-play-state: paused; }
  @keyframes cert-scroll {
    0%, 13.33%    { transform: translateX(0); }
    20%, 33.33%   { transform: translateX(-6.6667%); }
    40%, 53.33%   { transform: translateX(-13.3333%); }
    60%, 73.33%   { transform: translateX(-20%); }
    80%, 93.33%   { transform: translateX(-26.6667%); }
    100%          { transform: translateX(-33.3333%); }
  }

  /* 4. FEATURES */
  .features { background: var(--color-white); }
  .feature-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 2rem; }
  .feature-card { text-align: center; }
  .feature-text { color: var(--color-heading); font-size: 1.05rem; font-weight: 700; margin-bottom: 1.25rem; }
  .feature-img { overflow: hidden; aspect-ratio: 4 / 3; background: var(--color-light); }
  .feature-img img { width: 100%; height: 100%; object-fit: cover; }

  /* 5. PRE-ORDER */
  .preorder { background: radial-gradient(circle at 30% 25%, #a80000, #1a0000 78%); color: #e6e6e6; padding: 3.75rem 0; }
  .preorder-inner { display: grid; grid-template-columns: 1.1fr 0.9fr; gap: 3rem; align-items: center; }
  .preorder-copy h2 { color: var(--color-white); font-family: var(--font-display); font-weight: 800; font-size: clamp(1.7rem, 3.4vw, 2.4rem); }
  .preorder-copy p { color: #cfcfcf; font-size: 1rem; }
  .preorder-cta { padding: 0.6em 2em; }
  .preorder-count { margin: 1.25rem 0 0.25rem; }
  .big-num { font-family: var(--font-display); font-weight: 800; font-size: clamp(2.8rem, 6vw, 4rem); color: var(--color-yellow); line-height: 1; }
  .preorder-note { color: #cfcfcf; font-size: 0.95rem; }
  .stat-cards { list-style: none; padding: 0; margin: 0; display: grid; gap: 1rem; }
  .stat-card { display: flex; flex-direction: column; align-items: center; justify-content: center; text-align: center; gap: 0.6rem; background: var(--color-white); color: var(--color-heading); border-radius: 12px; padding: 1.5rem 1.25rem; box-shadow: 0 10px 24px rgba(0,0,0,0.25); }
  .stat-ic img { width: 34px; height: 34px; object-fit: contain; }
  .stat-txt { font-weight: 700; font-size: 1.05rem; }

  /* 6. VIDEO */
  .video { background: #fadbdc; padding: 4rem 0; }
  .video-card { position: relative; display: block; width: 100%; max-width: 1000px; margin-inline: auto; border-radius: 16px; overflow: hidden; box-shadow: 0 16px 40px rgba(0,0,0,0.2); padding: 0; border: 0; background: none; cursor: pointer; font: inherit; line-height: 0; }
  .video-card img { width: 100%; height: auto; display: block; }
  .video-card .play { position: absolute; left: 2.5%; bottom: 6%; width: 48px; height: 48px; border-radius: 50%; background: var(--color-white); display: grid; place-items: center; color: var(--color-black); transition: transform 0.15s ease; z-index: 1; }
  .video-card:hover .play { transform: scale(1.08); }
  .video-card .play svg { margin-left: 3px; }

  /* 7. TESTIMONIALS */
  .testimonials { position: relative; background-size: cover; background-position: center; padding: 5rem 0; }
  .shark-logo { position: absolute; top: 1.5rem; left: 1.75rem; height: clamp(52px, 7vw, 84px); width: auto; filter: drop-shadow(0 2px 10px rgba(0,0,0,0.5)); }
  .testimonial-stack { display: flex; flex-direction: column; gap: 1.5rem; max-width: 420px; margin: 0 auto; }
  .testimonial { display: flex; flex-direction: column; align-items: center; text-align: center; margin: 0; background: var(--color-white); border-radius: 16px; padding: 2rem; box-shadow: 0 12px 30px rgba(0,0,0,0.28); }
  .tst-photo { width: 84px; height: 84px; border-radius: 50%; object-fit: cover; margin-bottom: 1rem; }
  .testimonial blockquote { margin: 0 0 0.5rem; font-family: var(--font-display); font-weight: 800; font-size: 1.4rem; color: var(--color-heading); }
  .testimonial figcaption { color: var(--color-muted); font-size: 0.95rem; }

  /* 8. VALUE + LOCATIONS (dark red) */
  .value { background: radial-gradient(circle at 50% 0%, #b3000c, #6a0000 80%); color: var(--color-white); padding: 4.5rem 0; }
  .value-title { text-align: center; font-family: var(--font-display); font-weight: 800; font-size: clamp(1.9rem, 4vw, 2.8rem); color: var(--color-white); }
  .value-lead { max-width: 900px; margin: 0 auto 2.5rem; text-align: center; color: #f2d9da; font-size: 1.05rem; }
  .locations { list-style: none; padding: 0; margin: 0; display: grid; grid-template-columns: repeat(5, 1fr); gap: 1rem; }
  .loc-card { display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 0.75rem; text-align: center; background: rgba(0,0,0,0.18); border: 1px solid rgba(255,255,255,0.14); border-radius: 12px; padding: 1.5rem 0.75rem; }
  .loc-icon { width: 40px; height: 40px; object-fit: contain; }
  .loc-label { font-size: 0.9rem; font-weight: 600; color: var(--color-white); }

  /* 9. FOOD EMPIRE (single responsive banner image) */
  .empire { line-height: 0; }
  .empire img { width: 100%; height: auto; display: block; }

  /* RESPONSIVE */
  @media (max-width: 900px) {
    .hero-inner, .chef-inner, .preorder-inner { grid-template-columns: 1fr; }
    .hero-media { order: -1; }
    .feature-grid { grid-template-columns: 1fr; max-width: 480px; margin-inline: auto; }
    .locations { grid-template-columns: repeat(3, 1fr); }
    .testimonial-stack { max-width: none; }
  }
  @media (max-width: 520px) {
    .locations { grid-template-columns: repeat(2, 1fr); }
  }
</style>
