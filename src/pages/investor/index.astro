---
import BaseLayout from '../../layouts/BaseLayout.astro';

const navLinks = [
  { label: 'VISION', href: '#vision' },
  { label: 'OPPORTUNITY', href: '#opportunity' },
  { label: 'INNOVATION', href: '#innovation' },
  { label: 'ACCESS', href: '#access' },
  { label: 'SWEET ROBO', href: '#sweet-robo' },
  { label: 'MODEL', href: '#model' },
  { label: 'ROADMAP', href: '#roadmap' },
  { label: 'TEAM', href: '#team' },
  { label: 'FAQ', href: '#faq' },
];

const heroStats = [
  { prefix: '+', value: '1,000,000', label: 'Target Locations in the US alone.' },
  { prefix: '$', value: '100', suffix: '+ Million', label: 'Projected Annual Revenue by 2029' },
  { prefix: '$', value: '1.5', suffix: 'M Shark Tank Offer', label: 'From Kevin O’Leary and Michael Rubin' },
];

const opportunityCards = [
  { title: 'Market Size', lines: ['Americans consume 50B burgers annually', '$868B U.S. fast-food market'] },
  { title: 'Labor Challenges', lines: ['70% of restaurants face staffing shortages', 'Rising labor costs squeeze profitability'] },
  { title: 'Consumer Demands', lines: ['Expectations for hot, fresh food anytime', 'Consumers want speed without compromise'] },
  { title: 'Automation Momentum', lines: ['70% of consumers open to automated service', 'Confidence in tech driven dining is growing'] },
