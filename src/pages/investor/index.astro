const socialProofPoints = [
  { bold: '$7M+ raised,', rest: ' with a $1.5M Shark Tank offer from Kevin O’Leary and Michael Rubin' },
  { bold: 'Featured in Forbes, TechCrunch, NY Post,', rest: ' and dozens other prominent outlets' },
  { bold: 'Over 4.4 billion', rest: ' global media impressions' },
  { bold: 'More than $38M', rest: ' in earned media value' },
];

const mediaLogos = [
  '/images/investor/WNBC_4_NY.svg-1.png',
  '/images/investor/Drew_Barrymore_Show_logo.svg-1.png',
  '/images/investor/150px-WNYW5-1.png',
  '/images/investor/The_Talk_logo_2021-1.png',
  '/images/investor/Today_logo.svg-1.png',
  '/images/investor/The_Tonight_Show_Starring_Jimmy_Fallon.svg-1.png',
];

const team = [
  { name: 'Piny Vind', title: 'President', bio: 'Founder of Sweet Robo, with a track record of building and scaling robotic vending products used in 25+ countries' },
  { name: 'Dennis Branch', title: 'CRO', bio: 'Revenue leader with $2.4B in startup exits, including roles in AI, biometrics, and fintech; ex-Clearwire (acquired by SoftBank)' },
  { name: 'Dan Braido', title: 'CTO', bio: 'PhD engineer and former Siemens Principal Engineer with 18+ years of experience in hardware, automation, and systems integration.' },
  { name: 'Andy Siegel', title: 'CMO', bio: 'Built multiple $100M+ DTC brands in wellness and lifestyle; 40 years in media, marketing, and subscription growth.' },
  { name: 'Tzlil Berko', title: 'CPO', bio: 'Extensive experience leading large teams and managing complex, high-impact projects across corporate and government sectors.' },
  { name: 'Audley Wilson', title: 'CEO', bio: 'Former VP of Analytics at top consumer brands and a 12-year restaurant operations veteran, uniquely bridging food and tech.' },
];

const faqs = [
  { q: 'What does this investment give me?', a: 'Investing gives you ownership in RoboBurger in the form of shares. As the company grows, your investment may increase in value, and you participate in the company’s long-term success.' },
  { q: 'What is StartEngine?', a: 'StartEngine is a leading U.S. equity crowdfunding platform that allows individuals to invest in private companies online. It connects startups with investors and manages the legal and financial process of the investment.' },
  { q: 'What is equity crowdfunding?', a: 'Equity crowdfunding allows individuals to invest in private companies in exchange for ownership (shares). Unlike traditional investing, it gives access to early-stage opportunities that were previously limited to venture capital firms.' },
  { q: 'Is this a risky investment?', a: 'Yes. Investing in early-stage companies involves risk, including the potential loss of your entire investment. However, it also offers the opportunity for high returns if the company succeeds.' },
  { q: 'How do I make money from this investment?', a: 'Returns may come from a future acquisition, public offering (IPO), or other liquidity events. In some cases, companies may also distribute profits, but most early-stage investments focus on long-term growth.' },
  { q: 'Who can invest?', a: 'Both accredited and non-accredited investors can participate, depending on regulations. Investment limits may apply based on income and net worth.' },
  { q: 'What makes RoboBurger unique?', a: 'RoboBurger is the only machine of its kind that prepares a fresh burger completely autonomously inside a single unit. Protected by patents and purpose-built technology, it replaces an entire fast-food operation with a compact, automated system. RoboBurger is not just a product — it is building the first fully automated burger empire.' },
  { q: 'Who is Sweet Robo and what is their role?', a: 'Sweet Robo is a global leader in robotic vending machines, with thousands of machines deployed and tens of millions of dollars in sales. Sweet Robo is now an official partner in RoboBurger and will lead large-scale growth, including manufacturing, deployment, and expansion. Their proven expertise in automated retail positions RoboBurger to scale rapidly and confidently.' },
];

const partners = [
  '/images/partners/Robo-Burger-Investor-Brief-16.webp',
  '/images/partners/Robo-Burger-Investor-Brief-17.webp',
  '/images/partners/Robo-Burger-Investor-Brief-18.webp',
  '/images/partners/Robo-Burger-Investor-Brief-19.webp',
  '/images/partners/Robo-Burger-Investor-Brief-20.webp',
  '/images/partners/Robo-Burger-Investor-Brief-21.webp',
  '/images/partners/Robo-Burger-Investor-Brief-22.webp',
  '/images/partners/Robo-Burger-Investor-Brief-23.webp',
  '/images/partners/Path-397.webp',
  '/images/partners/Path-438.webp',
  '/images/partners/Robo-Burger-Investor-Brief-26.webp',
  '/images/partners/Robo-Burger-Investor-Brief-27.webp',
  '/images/partners/Robo-Burger-Investor-Brief-29.webp',
  '/images/partners/Robo-Burger-Investor-Brief-34.webp',
  '/images/partners/Robo-Burger-Investor-Brief-37.webp',
  '/images/partners/five-star-parks-attractions-1-300x158-1.webp',
];

const stats = [
  { regular: '/images/roboburger/stat1-regular.webp', hover: '/images/roboburger/stat1-hover.webp', text: 'Thousands of machines sold in 25+ countries, serving millions of customers worldwide.' },
  { regular: '/images/roboburger/stat2-regular.webp', hover: '/images/roboburger/stat2-hover.webp', text: 'Developed a portfolio of 15+ groundbreaking machines and robots, from cotton candy to ice cream and popcorn pushing the limits of automated retail.' },
  { regular: '/images/roboburger/stat3-regular.webp', hover: '/images/roboburger/stat3-hover.webp', text: 'Powered by dozens of top tier engineers, developers, designers, and tech specialists.' },
  { regular: '/images/roboburger/stat4-regular.webp', hover: '/images/roboburger/stat4-hover.webp', text: 'Trusted by top global brands, with active partnerships across leading retail, entertainment, and hospitality sectors.' },
];
---
<BaseLayout title="Investor | RoboBurger" description="Invest in RoboBurger — the world's first fully autonomous burger robot disrupting a $868B industry." bare>
  <!-- ANNOUNCEMENT BAR -->
  <div class="announce-bar">
    Invest Now to unlock up to 10% bonus shares
  </div>

  <!-- CUSTOM HEADER -->
  <header class="inv-header">
    <div class="container inv-header-inner">
      <a href="/" class="inv-logo" aria-label="RoboBurger home">
        <img src="/logo.png" alt="RoboBurger" width="130" height="34" />
      </a>
      <nav class="inv-nav" aria-label="Investor page sections">
        {navLinks.map((l) => <a href={l.href}>{l.label}</a>)}
      </nav>
      <a href="#access" class="btn-invest">INVEST NOW <span class="arrow">&rarr;</span></a>
      <button type="button" class="inv-menu-toggle" aria-label="Open menu" aria-expanded="false">
        <span></span><span></span><span></span>
      </button>
    </div>
    <nav class="inv-mobile-nav" aria-label="Investor page sections (mobile)">
      {navLinks.map((l) => <a href={l.href}>{l.label}</a>)}
    </nav>
  </header>

  <script>
    const toggle = document.querySelector('.inv-menu-toggle');
    const mobileNav = document.querySelector('.inv-mobile-nav');
    toggle?.addEventListener('click', () => {
      const open = mobileNav?.classList.toggle('is-open');
      toggle.setAttribute('aria-expanded', open ? 'true' : 'false');
      toggle.classList.toggle('is-open', open);
    });
    mobileNav?.querySelectorAll('a').forEach((a) => {
      a.addEventListener('click', () => {
        mobileNav.classList.remove('is-open');
        toggle?.setAttribute('aria-expanded', 'false');
        toggle?.classList.remove('is-open');
      });
    });
  </script>

  <!-- HERO -->
  <section class="inv-hero">
    <div class="container inv-hero-inner">
      <div class="inv-hero-copy">
        <h1>The World's First Burger Robot Disrupting a $868B Industry</h1>
        <p class="inv-hero-lead"><strong>Invest in the Future, Invest in RoboBurger</strong></p>
        <p class="inv-hero-desc">
          RoboBurger is the first and only fully autonomous burger machine that grills and serves fresh, hot
          burgers on demand. Compact, self-cleaning, and certified for food and electrical safety, it operates
          without staff, kitchen, or ventilation and backed by multiple patents.
        </p>
        <a href="#access" class="btn-cta">I'M READY FOR THE FUTURE <span class="arrow">&rarr;</span></a>
      </div>
      <div class="inv-hero-media">
        <a href="https://youtu.be/oJfQ7CfB4-E" target="_blank" rel="noopener" class="hero-video-wrap" aria-label="Watch video">
          <video src="/videos/hero-video.mp4" autoplay muted loop playsinline></video>
          <span class="play-icon" aria-hidden="true">&#9654;</span>
        </a>
      </div>
    </div>

    <div class="container inv-hero-bottom">
      <div class="inv-testimonial">
        <img class="testimonial-photo" src="/images/investor/image__1_-removebg-preview.png" alt="Michael Rubin" loading="lazy" />
        <div class="testimonial-card">
          <p class="quote">&ldquo;It could be massive, it could be a billion-dollar business&rdquo;</p>
          <p class="attribution">- Michael Rubin, Shark Tank</p>
          <img class="shark-logo" src="/images/roboburger/shark-tank-logo.webp" alt="Shark Tank" loading="lazy" />
        </div>
      </div>
      <ul class="inv-hero-stats">
        {heroStats.map((s) => (
          <li>
            <p class="stat-value">{s.prefix}{s.value}<span>{s.suffix}</span></p>
            <p class="stat-label">{s.label}</p>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- VISION -->
  <section class="inv-section vision-section" id="vision">
    <div class="container vision-inner">
      <div class="vision-copy">
        <p class="eyebrow">VISION</p>
        <h2>This Is the End of the Fast Food Kitchen</h2>
        <p class="desc-text">
          We're making fast food as you know it obsolete. We're turning empty corners into high-profit food
          destinations. We're creating a future where fresh, hot food is delivered reliably, 24/7, with zero labor
          headaches. We've patented the technology. We've proven demand. And now you have the opportunity to
          invest at a critical moment and join us as we scale.
        </p>
        <a href="#access" class="btn-cta">INVEST FROM $500 <span class="arrow">&rarr;</span></a>
      </div>
      <div class="vision-media">
        <img src="/images/investor/s4-Photoroom-1.webp" alt="RoboBurger machine" loading="lazy" class="vision-machine" />
        <img src="/images/investor/robo-burger-chief2-1.jpg" alt="" loading="lazy" class="vision-chef" />
      </div>
    </div>
  </section>

  <!-- OPPORTUNITY -->
  <section class="inv-section" id="opportunity">
    <div class="container">
      <div class="inv-section-head">
        <p class="eyebrow">OPPORTUNITY</p>
        <h2>A $868B Market Starved For Disruption</h2>
        <p class="desc-text">
          Americans eat 50 billion burgers every year. But the $868B fast food industry is facing a fundamental
          shift. Traditional restaurants can't keep pace with evolving consumer demands or operational challenges.
        </p>
      </div>
      <div class="opportunity-grid">
        {opportunityCards.map((c) => (
          <div class="opportunity-card">
            <h3>{c.title}</h3>
            {c.lines.map((l) => <p>{l}</p>)}
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- INNOVATION -->
  <section class="inv-section" id="innovation">
    <div class="container innovation-inner">
      <div class="innovation-media">
        <img src="/images/investor/s4-Photoroom-1.webp" alt="" loading="lazy" />
        <img src="/images/investor/0001_Select-2.png" alt="" loading="lazy" />
        <img src="/images/investor/7_RoboBurger_Newport-1.png" alt="" loading="lazy" />
        <img src="/images/investor/im.webp" alt="" loading="lazy" />
      </div>
      <div class="innovation-copy">
        <p class="eyebrow">INNOVATION</p>
        <h2>A Fully Automated Burger Kitchen in Just 10 Square Feet</h2>
        <ul class="innovation-list">
          {innovationFeatures.map((f) => (
            <li>
              <img src={f.icon} alt="" aria-hidden="true" loading="lazy" />
              <div>
                <h3>{f.title}</h3>
                <p>{f.text}</p>
              </div>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <!-- ACCESS / GET EQUITY -->
  <section class="access-banner" id="access">
    <div class="container">
      <h2>Join the Company Disrupting the Multi-Billion Dollar Burger Industry</h2>
      <p class="access-sub">Starting from $500</p>
      <p class="access-sub2">Own equity at $5 per share</p>
      <p class="access-note">*Invest securely through StartEngine*</p>
      <a href="https://www.startengine.com/" target="_blank" rel="noopener" class="btn-cta btn-cta-light">GET EQUITY <span class="arrow">&rarr;</span></a>
    </div>
  </section>

  <!-- TRACTION -->
  <section class="inv-section">
    <div class="container traction-inner">
      <div class="traction-media">
        <img src="/images/investor/Asset-1@4x-100-1.png" alt="" loading="lazy" />
        <img src="/images/investor/Asset-1@4x-100-2.png" alt="" loading="lazy" />
      </div>
      <div class="traction-copy">
        <p class="eyebrow">TRACTION</p>
        <h2>Built to Scale. Proven in the Real World.</h2>
        <p class="traction-headline">PROVEN IN THE REAL WORLD WITH 3,000+ PURCHASE REQUESTS ALREADY</p>
        <p class="desc-text">
          After years of R&amp;D and real world testing, you're investing in a company that's done the hard part
          building a machine the world actually wants.
        </p>
        <a href="#access" class="btn-cta">INVEST NOW <span class="arrow">&rarr;</span></a>
      </div>
    </div>
    <div class="container">
      <div class="traction-grid">
        {tractionCards.map((c) => (
          <div class="traction-card">
            <h3>{c.title}</h3>
            <p>{c.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- SWEET ROBO (reused from About page) -->
  <section class="sweet-robo" id="sweet-robo">
    <div class="container sweet-robo-inner">
      <div class="sweet-robo-media">
        <img src="/images/about/sweet-robo-collage.png" alt="Sweet Robo vending machines" loading="lazy" />
      </div>
      <div class="sweet-robo-copy">
        <p class="eyebrow">SWEET ROBO</p>
        <h2>New Partnership with Sweet Robo</h2>
        <p class="desc-text">
          RoboBurger has joined forces with Sweet Robo the largest leader in robotics vending. This partnership
          brings proven scale, deep technical resources, and a global track record in automated vending.
        </p>
        <a href="#access" class="btn-cta">INVEST NOW <span class="arrow">&rarr;</span></a>
      </div>
    </div>

    <div class="stats-wrap">
      <div class="stats-card">
        <ul class="stat-grid">
          {stats.map((s) => (
            <li class="stat-hover-col">
              <span class="stat-icon-wrap">
                <img src={s.regular} alt="" aria-hidden="true" class="stat-icon-regular" loading="lazy" />
                <img src={s.hover} alt="" aria-hidden="true" class="stat-icon-hover" loading="lazy" />
              </span>
              <p>{s.text}</p>
            </li>
          ))}
        </ul>

        <div class="scale-banner-inner">
          <div class="scale-text-block">
            <p class="scale-text">
              <strong>3 warehouses, 4 offices, 5 manufacturing facilities</strong>, and over <strong>200 global employees</strong> all
              ready to scale RoboBurger to the next level.
            </p>
          </div>
          <div class="scale-logo-block">
            <div class="partner-marquee">
              <ul class="partner-track">
                {[...partners, ...partners].map((src) => (
                  <li><img src={src} alt="" loading="lazy" /></li>
                ))}
              </ul>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- EMAIL CAPTURE CTA -->
  <section class="email-cta">
    <div class="container">
      <h2>Access the Full Business Plan</h2>
      <p>Drop your email to get instant access to our investor brief, business overview, and next gen machine rollout strategy</p>
      <form class="email-form" onsubmit="event.preventDefault();">
        <input type="email" required placeholder="Enter your email" aria-label="Email address" />
        <button type="submit" class="btn-cta">I'M READY FOR THE FUTURE <span class="arrow">&rarr;</span></button>
      </form>
    </div>
  </section>

  <!-- BUSINESS MODEL -->
  <section class="inv-section" id="model">
    <div class="container">
      <div class="inv-section-head">
        <p class="eyebrow">BUSINESS MODEL</p>
        <h2>How RoboBurger Makes Money</h2>
        <p class="desc-text">A multi-channel model designed for recurring revenue and global growth.</p>
      </div>
      <ul class="model-list">
        {modelItems.map((m) => (
          <li>
            <img src="/images/investor/ok.svg" alt="" aria-hidden="true" />
            <div>
              <h3>{m.title}</h3>
              <p>{m.text}</p>
            </div>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- ROADMAP -->
  <section class="inv-section" id="roadmap">
    <div class="container">
      <div class="inv-section-head">
        <p class="eyebrow">ROADMAP</p>
        <h2>Our Plan for $100M Annual Revenue by 2029</h2>
        <p class="desc-text">
          RoboBurger is poised to unlock drastically improved economics with our Gen 3 robot, featuring 2X burger
          capacity, faster cooking speeds, and 47% cheaper unit production. Your investment will help launch this
          next-gen tech and scale to 6,900+ units deployed by 2029
        </p>
      </div>
      <h3 class="tam-title">Total Addressable Market by Vertical</h3>
      <p class="tam-source">
        Below is a breakdown of our estimated TAM by vertical and region. Sources: U.S. Census Bureau County
        Business Patterns (CBP 2022 &amp; 2023).
      </p>
      <ul class="tam-list">
        {tamSectors.map((t) => (
          <li>
            <p><strong>{t.title}</strong> {t.desc}</p>
            <p class="tam-count">{t.count}<span> Businesses</span></p>
          </li>
        ))}
        <li class="tam-total">
          <p>Total Market Potential:</p>
          <p class="tam-count">1,029,556<span> Businesses</span></p>
        </li>
      </ul>
    </div>
  </section>

  <!-- BOOK A SESSION -->
  <section class="session-banner">
    <div class="container session-inner">
      <div>
        <h2>Considering an investment of $5,000+?</h2>
        <p>Book a private session with our team for a deeper look at the company and opportunity.</p>
        <a href="https://calendly.com/bruce-sweetrobo/30min" target="_blank" rel="noopener" class="btn-cta btn-cta-light">BOOK A SESSION <span class="arrow">&rarr;</span></a>
      </div>
    </div>
  </section>

  <!-- SOCIAL PROOF -->
  <section class="inv-section social-proof">
    <div class="container">
      <p class="eyebrow">SOCIAL PROOF</p>
      <h2>Sharks, Media, and Diners Keep Biting</h2>
      <p class="desc-text">
        RoboBurger has already caught the attention of both the press and prominent backers, and the momentum
        just keeps on building.
      </p>
      <ul class="social-proof-list">
        {socialProofPoints.map((p) => (
          <li>
            <img src="/images/investor/ok.svg" alt="" aria-hidden="true" />
            <p><strong>{p.bold}</strong>{p.rest}</p>
          </li>
        ))}
      </ul>
      <div class="media-logos">
        {mediaLogos.map((src) => <img src={src} alt="" loading="lazy" />)}
      </div>
      <div class="quotes-row">
        <div class="quote-card">
          <img src="/images/investor/image__1_-removebg-preview.png" alt="Michael Rubin" loading="lazy" />
          <p class="quote">&ldquo;This is a big idea!&rdquo;</p>
          <p class="attribution">- Michael Rubin</p>
        </div>
        <div class="quote-card">
          <p class="quote">&ldquo;The burger is really good!&rdquo;</p>
          <p class="attribution">-Lori Greiner</p>
        </div>
      </div>
    </div>
  </section>

  <!-- TEAM -->
  <section class="inv-section" id="team">
    <div class="container">
      <div class="inv-section-head">
        <p class="eyebrow">OUR LEADERSHIP TEAM</p>
        <h2>Built by Experts in Robotics, Food, and Scalable Tech</h2>
