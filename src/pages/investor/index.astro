  { icon: '/images/investor/Group-1000009163.png', title: 'Patented Safety', text: '5 U.S. patents, verified food safety tec' },
];

const tractionCards = [
  { title: 'Pilot Success', text: 'Deployed in casinos, retail hubs, and convenience stores with 82% repurchase.' },
  { title: 'Global Demand', text: 'Over 3,000 purchase requests submitted worldwide, reflecting strong interest.' },
  { title: 'Enterprise Talks', text: 'Advanced discussions underway with leaders in food, retail, and hospitality.' },
];

const modelItems = [
  { title: 'MACHINE SALES', text: 'High-margin units sold to retail, entertainment, and institutional venues' },
  { title: 'LEASING & FINANCING', text: 'Flexible options generating predictable monthly cash flow' },
  { title: 'CONSUMABLES', text: 'Recurring revenue from proprietary patties, buns, sauces, and packaging' },
  { title: 'COMPANY - OPERATED UNITS', text: 'Direct burger sales from high-traffic locations' },
  { title: 'SOFTWARE SUBSCRIPTIONS', text: 'Monthly fees for remote monitoring, inventory, and performance data' },
  { title: 'ENTREPRENEUR PARTNERS', text: 'Trained individuals running their own RoboBurger units' },
  { title: 'SERVICE & PARTS', text: 'Revenue from maintenance contracts and replacement components' },
  { title: 'CUSTOM - BRANDED MACHINES', text: 'Co-branded units with major food and retail brands' },
  { title: 'GLOBAL DISTRIBUTION', text: 'Regional partners expanding across international market' },
];

const tamSectors = [
  { title: 'Food sector', desc: 'including supermarkets, convenience stores and other food outlets.', count: '206,855' },
  { title: 'Broad retail sector', desc: 'including department stores, pharmacies, shopping malls and super centers.', count: '74,361' },
  { title: 'Entertainment & sports sector', desc: 'including amusement, FEC, arenas, sports centers and other venues.', count: '79,695' },
  { title: 'Food & beverage sector', desc: 'including food courts, fast food, beverage/alcoholic bars.', count: '402,966' },
  { title: 'Hospitality sector', desc: 'including hotels, resorts, cruises and casinos.', count: '67,134' },
  { title: 'Institutional sector', desc: 'including hospitals, government facilities, universities and campuses.', count: '116,970' },
  { title: 'Additional sectors', desc: 'including office buildings, airports, marinas, gas stations.', count: '81,575' },
