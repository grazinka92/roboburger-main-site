  { icon: '/images/investor/Group-12.png', title: 'Grills in 3.5 Min', text: 'Fresh, hot burgers - never reheated.' },
  { icon: '/images/investor/Group-12-1.png', title: 'Customizable Menu', text: '3 patty types, 6 sauces, 3 toppings.' },
  { icon: '/images/investor/Group-12-2.png', title: 'No Kitchen Needed', text: '10sq.ft., plug & play, self-cleaning.' },
  { icon: '/images/investor/Group-12-3.png', title: 'Interactive Experience', text: 'Touchscreen and live cooking window.' },
  { icon: '/images/investor/Group-12-4.png', title: 'Smart & Connected', text: 'AI system, built in cameras, remote monitoring app.' },
