---
import BaseLayout from '../../layouts/BaseLayout.astro';

const specsA = [
  { label: 'Capacity', value: 'Approximately 70 burgers per refill' },
  { label: 'Electricity', value: '220V 11A, 110V 22A' },
  { label: 'Dimensions', value: 'H 233 / W 145 / D 75 cm — H 91.7 / W 57.09 / D 29.53 in' },
];

const specsB = [
  { label: 'Capacity', value: 'Approximately 70 burgers per refill' },
  { label: 'Electricity', value: '220V 30 amp' },
  { label: 'Dimensions', value: 'H 130 / W 185 / D 71 cm — H 73 / W 51 / D 28 in' },
];

const menuCards = [
  { icon: '/images/menu-icon-patty.png', title: '3 Patty Options', text: 'Enabling a diverse menu selection (Such as beef, chicken, plant-based)' },
  { icon: '/images/menu-icon-topping.png', title: '3 Topping Types', text: 'Topping Dispenser Accommodates 3 varieties, (such as cheese, pickles, fried onion)' },
  { icon: '/images/menu-icon-sauce.png', title: '6 Sauce Choices', text: 'From classic ketchup to gourmet flavors' },
  { icon: '/images/menu-icon-bun.png', title: 'Toasted Bun', text: 'Warm and crispy for perfect texture.' },
];

const features = [
  { img: '/images/features/work-1.gif', title: 'No Plumbing Required', text: 'Install anywhere using just a standard outlet.' },
  { img: '/images/features/mop.gif', title: 'Self-Cleaning System', text: 'Maintains hygiene without extra labor.' },
  { img: '/images/features/camera.gif', title: 'Built in Cameras', text: 'Ensure quality and security at all times.' },
  { img: '/images/features/evidence.gif', title: 'Real Time Viewing', text: 'Watch every burger being made fresh' },
  { img: '/images/features/plug-and-play.gif', title: 'Plug & Play', text: 'Quick setup for instant business launch.' },
  { img: '/images/features/menu.gif', title: 'Customizable Menu', text: 'Adapt meals to match customer tastes.' },
  { img: '/images/features/customer-support.gif', title: 'Remote Monitoring', text: 'Track and control operations online.' },
  { img: '/images/features/certificate-authority-2.gif', title: 'Patented Technology', text: 'Exclusive system with proven innovation.' },
];

const benefits = [
  { title: 'Low operating costs', img: '/images/benefits/1-low-cost.webp' },
  { title: 'High customer engagement', img: '/images/benefits/2-engagement.png' },
  { title: 'No need for kitchen space or<br />staff', img: '/images/benefits/3-no-kitchen.png' },
  { title: 'Real food with real margins', img: '/images/benefits/4-real-food.webp' },
  { title: 'Easy to maintain and<br />monitor remotely', img: '/images/benefits/5-maintain.png' },
  { title: 'Scalable from 1 to 100+ units', img: '/images/benefits/6-scalable.png' },
];

const gen3Features = [
  { icon: '/images/prod-capacity.png', text: 'Higher production capacity – more burgers per refill' },
  { icon: '/images/prod-inspiration.png', text: 'Striking new design – sleek, modern, and eye-catching' },
  { icon: '/images/prod-window.png', text: 'Live viewing window – lets customers see part of the cooking process' },
  { icon: '/images/prod-compact-disc.png', text: 'Compact footprint – fits easily in high-traffic locations' },
  { icon: '/images/prod-inspiration.png', text: 'Striking new design – sleek, modern, and eye-catching' },
  { icon: '/images/prod-window.png', text: 'Live viewing window – lets customers see part of the cooking process' },
];

const stats = [
  { icon: 'rocket', text: 'Limited Launch: Only 200 machines available' },
  { icon: 'coins', text: 'Secure Yours Today: Pay just $5,000 upfront' },
  { icon: 'tag', text: 'Special Pre-Order Price: $27,500' },
];
---
<BaseLayout
  title="Our Product | RoboBurger"
  description="Discover the Future of Burgers — Enjoy Fresh, Hot, Perfectly Crafted Burgers Made by Our Cutting Edge Robotic Technology."
>
  <!-- HERO (plain gradient banner, title only) -->
  <section class="hero">
    <div class="container">
      <h1>Our Product</h1>
    </div>
  </section>

  <!-- AUTONOMOUS KITCHEN (light section, 2-column, black text) -->
  <section class="kitchen">
    <div class="container kitchen-inner">
      <div class="kitchen-copy">
        <h2>The Autonomous<br />Burger Kitchen</h2>
        <p>Serve Real Burgers. No Staff. No Kitchen. Just Plug It In.</p>
        <a href="https://calendly.com/bruce-sweetrobo/30min" target="_blank" rel="noopener" class="btn btn-primary own-one-btn">Own One</a>
      </div>
      <div class="kitchen-media">
        <img src="/images/prod-kitchen-machine.png" alt="RoboBurger autonomous burger machine" width="632" height="573" />
      </div>
    </div>
  </section>

  <!-- A PLUG & GO (red gradient bg, white bordered image, white text) -->
  <section class="plug-go">
    <div class="container plug-go-inner">
      <div class="plug-go-media">
        <img src="/images/prod-select.png" alt="Customer receiving a fresh RoboBurger" loading="lazy" />
      </div>
      <div class="plug-go-copy">
        <h2 class="section-title-left">A Plug &amp; Go Burger Restaurant in Miniature</h2>
        <p class="desc-text">
          RoboBurger is a revolutionary food automation kiosk that grills fresh, gourmet burgers in
          approximately 3.5 minutes no staff, no kitchen, no complications. This compact, 10 square foot
          unit is fully self-operating and self-cleaning. Inside, RoboBurger integrates refrigeration,
          grilling, assembly, and packaging systems into a single automated solution. The machine toasts
          the bun, grills the patty, and assembles the burger in a sealed box all autonomously. Condiments
          and toppings are provided separately in portioned packets, allowing customers to select from
          multiple options. The unit includes secure digital payments, real-time cloud monitoring for
          inventory and performance, and is designed to meet food safety standards with minimal on-site
          servicing.
        </p>
      </div>
    </div>
  </section>

  <!-- PRODUCT SPECIFICATIONS + MENU CUSTOMIZATION CARDS -->
  <section class="section specs-menu">
    <div class="container specs-menu-inner">
      <div class="specs-col">
        <h2 class="section-title-left">Product specifications</h2>
        <ul class="spec-list">
          {specsA.map((s) => (<li><strong>{s.label}:</strong><br />{s.value}</li>))}
        </ul>
      </div>
      <div class="menu-cards">
        {menuCards.map((c) => (
          <div class="menu-card">
            <img src={c.icon} alt="" aria-hidden="true" class="menu-card-icon" loading="lazy" />
            <h3>{c.title}</h3>
            <p>{c.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- SPECS B -->
  <section class="section specs-b">
    <div class="container">
      <ul class="spec-list centered">
        {specsB.map((s) => (<li><strong>{s.label}:</strong><br />{s.value}</li>))}
      </ul>
    </div>
  </section>

  <!-- KEY FEATURES GRID (8) -->
  <section class="section features8">
    <div class="container">
      <h2 class="section-title">Comprehensive, Compact, and One of a Kind</h2>
      <div class="features8-grid">
        {features.map((f) => (
          <article class="feature8-card">
            <img src={f.img} alt="" aria-hidden="true" loading="lazy" />
            <h3>{f.title}</h3>
            <p>{f.text}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- 3D VIEW -->
  <script type="module" src="https://unpkg.com/@google/model-viewer/dist/model-viewer.min.js"></script>
  <section class="section view3d">
    <div class="container">
      <h2 class="section-title">3D View</h2>
      <model-viewer
        src="/robo_burger.glb"
        alt="RoboBurger 3D Model"
        auto-rotate
        camera-controls
        ar
        style="width: 100%; height: 500px;"
      ></model-viewer>
    </div>
  </section>

  <!-- BUSINESS BENEFITS -->
  <section class="section benefits">
    <div class="container">
      <h2 class="section-title">RoboBurger isn't just a machine it's a business in a box.</h2>
      <p class="section-lead">
        Whether you're a property owner or an entrepreneur, RoboBurger gives you a powerful way to serve
        food, generate income, and grow a brand people remember.
      </p>
      <ul class="benefits-list">
        {benefits.map((b) => (
          <li>
            <h3 set:html={b.title} />
            <img src={b.img} alt={b.title.replace(/<br \/>/g, ' ')} loading="lazy" />
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- GEN 3 INFO -->
  <section class="section gen3-info">
    <div class="container gen3-inner">
      <div class="gen3-copy">
        <h2 class="section-title">What's New in Gen 3</h2>
        <p class="section-lead">
          The third generation of RoboBurger brings major upgrades designed for scale, performance, and
          visual impact
        </p>
        <img src="/images/gen3-machine.webp" alt="RoboBurger Gen 3 machine" class="gen3-machine-img" />
      </div>
      <ul class="gen3-features">
        {gen3Features.map((f) => (
          <li>
            <img src={f.icon} alt="" aria-hidden="true" class="gen3-icon" />
            <span>{f.text}</span>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- PRE-ORDER GEN 3 CTA -->
  <section class="preorder">
    <div class="container preorder-inner">
      <div class="preorder-copy">
        <h2>Pre Order<br />RoboBurger Gen 3</h2>
        <p>
          Gen 3 is finally here faster, smaller, higher capacity, more menu options, and upgraded
          quality. This is the first RoboBurger designed for mass production and global expansion.
        </p>
        <a href="/contact-us/" class="btn btn-primary preorder-cta">Contact Us To Reserve</a>
        <div class="preorder-count"><span class="big-num">128</span></div>
        <p class="preorder-note">Only 128 out of 200 are still available for pre order.</p>
      </div>
      <ul class="stat-cards">
        {stats.map((s) => (
          <li class="stat-card">
            <span class="stat-ic"><img src={`/images/icon-${s.icon}.png`} alt="" aria-hidden="true" /></span>
            <span class="stat-txt">{s.text}</span>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- REVOLUTION -->
  <section class="section revolution">
    <div class="container">
      <h2 class="section-title">Be Part of the Food Automation Revolution</h2>
      <p class="section-lead">
        The future of food isn't coming it's already here. Automated kitchens are transforming how,
        where, and when people eat. RoboBurger is at the forefront of this shift, offering not just a new
        way to serve food, but a new way to think about food businesses altogether. Whether you're an
        early adopter or a visionary entrepreneur, this is your moment to lead. Join the movement that's
        changing the face of food.
      </p>
      <a href="/contact-us/" class="btn btn-primary">Join the Revolution</a>
    </div>
  </section>

  <!-- BROCHURE -->
  <section class="section brochure">
    <div class="container brochure-inner">
      <h2 class="section-title">Product brochure</h2>
      <img src="/images/brochure-cover.webp" alt="RoboBurger brochure cover" loading="lazy" class="brochure-thumb" />
      <a href="/robo-burger-brochure.pdf" target="_blank" download class="btn btn-primary brochure-btn">Download Now</a>
    </div>
  </section>
</BaseLayout>

<style>
  .section { padding: 4.5rem 0; }
  .section-title { font-family: var(--font-display); font-weight: 800; font-size: clamp(1.9rem, 4vw, 2.8rem); text-align: center; line-height: 1.1; margin-bottom: 1rem; }
  .section-title-left { font-family: var(--font-display); font-weight: 800; font-size: clamp(1.7rem, 3.4vw, 2.4rem); line-height: 1.15; margin-bottom: 1.25rem; }
  .section-lead { max-width: 860px; margin: 0 auto 1.5rem; text-align: center; color: var(--color-text); font-size: 1.1rem; }

  /* HERO (plain gradient banner, title only) */
  .hero { background: linear-gradient(180deg, #C3000C 0%, #410101 100%); text-align: center; padding: 5rem 0; }
  .hero h1 { color: var(--color-white); font-family: var(--font-display); font-weight: 800; font-size: clamp(2.1rem, 5vw, 3.4rem); margin: 0; }

  /* AUTONOMOUS KITCHEN (light, 2-column) */
  .kitchen { background: var(--color-white); padding: 4.5rem 0; }
  .kitchen-inner { display: grid; grid-template-columns: 1fr 1fr; align-items: center; gap: 2.5rem; }
  .kitchen-copy h2 { color: #000000; font-family: var(--font-display); font-weight: 800; font-size: clamp(1.9rem, 4vw, 2.8rem); line-height: 1.15; margin-bottom: 1rem; }
  .kitchen-copy p { font-family: 'Poppins', sans-serif; font-size: 16px; color: #000000; margin-bottom: 1.5rem; }
  .own-one-btn {
    font-family: 'Poppins', sans-serif;
    font-size: 18px;
    color: #000000;
    background: #FFDD54;
    padding: 12px 24px;
  }
  .own-one-btn:hover { background: #ffd42e; color: #000000; }
  .kitchen-media img { margin-inline: auto; max-height: 450px; width: auto; object-fit: contain; }

  /* A PLUG & GO (red gradient, image keeps its own inner frame, white text) */
  .plug-go { background: linear-gradient(180deg, #C3000C 0%, #410101 100%); padding: 6rem 0; }
  .plug-go-inner { display: grid; grid-template-columns: 0.85fr 1.15fr; gap: 2.5rem; align-items: center; }
  .plug-go-media img {
    width: 100%; border-radius: 16px;
    box-shadow: 0 10px 30px rgba(0,0,0,0.35);
  }
  .plug-go-copy .section-title-left { color: #ffffff; }
  .plug-go-copy .desc-text { color: #ffffff; margin-bottom: 0; max-height: 260px; overflow: hidden; }

  /* PRODUCT SPECIFICATIONS + MENU CUSTOMIZATION */
  .specs-menu { background: var(--color-white); }
  .specs-menu-inner { display: grid; grid-template-columns: 0.8fr 1.2fr; gap: 1.5rem; align-items: start; }
  .specs-col .section-title-left { font-size: 42px; font-weight: 800; }
  .spec-list { list-style: none; padding: 0; margin: 0; display: grid; gap: 1rem; }
  .spec-list li { font-family: 'Poppins', sans-serif; font-size: 16px; color: #000000; }
  .spec-list strong { color: #DB0C15; font-weight: 700; }
  .spec-list.centered { text-align: center; max-width: 700px; margin-inline: auto; }
  .menu-cards { display: grid; grid-template-columns: repeat(2, 1fr); gap: 0.85rem; }
  .menu-card { display: flex; gap: 0.85rem; align-items: flex-start; background: #FADBDC; border-radius: 16px; padding: 20px; }
  .menu-card-icon { width: 64px; height: 64px; flex: none; object-fit: contain; }
  .menu-card h3 { font-family: 'Poppins', sans-serif; font-weight: 800; font-size: 20px; color: #000000; margin: 0 0 0.5rem; }
  .menu-card p { font-family: 'Poppins', sans-serif; font-size: 16px; color: #000000; margin: 0; }

  /* 3D VIEW */
  .view3d { background: var(--color-white); text-align: center; }
  .view3d model-viewer { max-width: 900px; margin-inline: auto; background: var(--color-light); border-radius: 12px; }

  /* SPECS B */
  .specs-b { background: var(--color-light); }

  /* FEATURES 8 */
  .features8 { background: linear-gradient(180deg, #C3000C 0%, #410101 100%); }
  .features8 .section-title { color: #ffffff; }
  .features8-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1.5rem; margin-top: 2rem; }
  .feature8-card { text-align: center; background: #ffffff; border-radius: 12px; padding: 1.75rem 1.25rem; }
  .feature8-card img { width: 64px; height: 64px; margin-inline: auto 0.75rem; object-fit: contain; }
  .feature8-card h3 { font-size: 1.05rem; margin: 0.75rem 0 0.4rem; color: #000000; }
  .feature8-card p { font-size: 0.92rem; color: var(--color-muted); }

  /* BENEFITS */
  .benefits {
    background: linear-gradient(180deg, #C3000C 0%, #410101 100%);
    padding: 3.5rem 0;
  }
  .benefits .section-title { font-family: 'Poppins', sans-serif; font-size: 44px; font-weight: 800; line-height: 1.25; color: #F5F5F5; }
  .benefits .section-lead { font-family: 'Poppins', sans-serif; font-size: 16px; line-height: 1.6; color: #ffffff; }
  .benefits-list {
    list-style: none; padding: 0; margin: 2.5rem 0 0;
    display: grid; grid-template-columns: repeat(3, 1fr); gap: 2.5rem 2rem;
  }
  .benefits-list li { text-align: center; }
  .benefits-list h3 {
    font-family: 'Poppins', sans-serif; font-size: 24px; font-weight: 600; line-height: 1.3; color: #ffffff;
    margin: 0 0 1.25rem; min-height: calc(1.3em * 2); display: flex; align-items: flex-end; justify-content: center;
  }
  .benefits-list img {
    width: 100%; aspect-ratio: 394 / 322; object-fit: cover;
    border-radius: 12px;
  }

  /* GEN 3 INFO */
  .gen3-info { background: var(--color-white); }
  .gen3-inner { display: grid; grid-template-columns: 1fr 1fr; gap: 3rem; align-items: center; }
  .gen3-copy .section-title { font-family: 'Poppins', sans-serif; font-size: 48px; font-weight: 800; line-height: 60px; color: #000000; text-align: left; }
  .gen3-copy .section-lead { font-family: 'Poppins', sans-serif; font-size: 16px; line-height: 28px; color: #000000; text-align: left; margin-top: 1rem; }
  .gen3-machine-img { display: block; height: 500px; max-width: 100%; object-fit: contain; object-position: left center; margin-top: 1.5rem; }

  .gen3-features {
    list-style: none; padding: 0; margin: 0;
    display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.25rem;
  }
  .gen3-features li {
    display: flex; flex-direction: column; align-items: center; text-align: center; gap: 0.75rem;
    background: linear-gradient(180deg, #BC010C 0%, #330000 100%);
    border-radius: 12px; padding: 1.75rem 1.25rem;
  }
  .gen3-features li span { font-family: 'Poppins', sans-serif; font-size: 16px; color: #ffffff; }
  .gen3-icon { width: 48px; height: 48px; flex: none; }

  /* PRE-ORDER (same pattern as home) */
  .preorder { background: radial-gradient(circle at 30% 25%, #a80000, #1a0000 78%); color: #e6e6e6; padding: 6rem 0; }
  .preorder-inner { display: grid; grid-template-columns: 1.1fr 0.9fr; gap: 3rem; align-items: center; }
  .preorder-copy h2 { color: var(--color-white); font-family: var(--font-display); font-weight: 800; font-size: clamp(2.4rem, 4.8vw, 3.6rem); line-height: 1.1; margin-bottom: 1.5rem; }
  .preorder-copy p { color: #ffffff; font-family: 'Poppins', sans-serif; font-size: 16px; line-height: 1.6; }
  .preorder-cta { padding: 0.65em 2.2em; font-size: 1.1rem; }
  .preorder-count { margin: 1.25rem 0 0.25rem; }
  .big-num { font-family: var(--font-display); font-weight: 800; font-size: clamp(3.6rem, 7.5vw, 5.5rem); color: var(--color-yellow); line-height: 1; }
  .preorder-note { color: #ffffff; font-family: 'Poppins', sans-serif; font-size: 20px; }
  .stat-cards { list-style: none; padding: 0; margin: 0; display: grid; gap: 1.25rem; }
  .stat-card { display: flex; flex-direction: column; align-items: center; justify-content: center; text-align: center; gap: 0.6rem; background: var(--color-white); color: var(--color-heading); border-radius: 12px; padding: 1.5rem 1.25rem; box-shadow: 0 10px 24px rgba(0,0,0,0.25); }
  .stat-ic img { width: 34px; height: 34px; object-fit: contain; }
  .stat-txt { font-weight: 700; font-size: 1.05rem; }

  /* REVOLUTION */
  .revolution { background: var(--color-white); text-align: center; }

  /* BROCHURE */
  .brochure { background: var(--color-white); text-align: center; }
  .brochure-inner { display: flex; flex-direction: column; align-items: center; }
  .brochure-thumb { width: 100%; max-width: 420px; border-radius: 8px; margin: 2rem 0 2.5rem; box-shadow: 0 20px 45px rgba(0, 0, 0, 0.25); }
  .brochure-btn { white-space: nowrap; }

  /* RESPONSIVE */
  @media (max-width: 900px) {
    .kitchen-inner, .plug-go-inner, .specs-menu-inner, .preorder-inner, .gen3-inner { grid-template-columns: 1fr; }
    .menu-cards { grid-template-columns: 1fr; }
    .kitchen-media { order: -1; }
    .features8-grid { grid-template-columns: repeat(2, 1fr); }
    .benefits-list { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 520px) {
    .features8-grid { grid-template-columns: 1fr; }
    .gen3-features { grid-template-columns: 1fr; }
    .benefits-list { grid-template-columns: 1fr; }
  }
</style>
