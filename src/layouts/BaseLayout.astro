---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
  bare?: boolean;
}
const { title, description = '', bare = false } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    <link rel="icon" type="image/png" href="/favicon.png" />

    <!-- Montserrat (some headings) + Poppins (widely used across the live site's Elementor content) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Montserrat:wght@700;800&family=Poppins:wght@400;500;600;700;800&display=swap"
    />

    <!-- Analytics (Google Tag Manager) is added in Task 11 with cookie consent. -->
  </head>
  <body>
    {bare ? <main><slot /></main> : <><Header /><main><slot /></main><Footer /></>}
  </body>
</html>
